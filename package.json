{
  "name": "ethiopia-geo-boundaries",
  "version": "3.0.2",
  "description": "Vanilla SVG generator for Ethiopian administrative boundaries (ADM1-ADM3). Zero runtime dependencies.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./adm1": {
      "types": "./dist/adm1.d.ts",
      "import": "./dist/adm1.js",
      "require": "./dist/adm1.cjs",
      "default": "./dist/adm1.js"
    },
    "./adm2": {
      "types": "./dist/adm2.d.ts",
      "import": "./dist/adm2.js",
      "require": "./dist/adm2.cjs",
      "default": "./dist/adm2.js"
    },
    "./adm3": {
      "types": "./dist/adm3.d.ts",
      "import": "./dist/adm3.js",
      "require": "./dist/adm3.cjs",
      "default": "./dist/adm3.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsx scripts/build-svg-paths.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ethiopia",
    "geojson",
    "boundaries",
    "svg",
    "map"
  ],
  "license": "ODC-PDDL-1.0",
  "devDependencies": {
    "@turf/helpers": "^7.3.5",
    "@turf/union": "^7.3.5",
    "@types/d3-geo": "^3.0.0",
    "@types/node": "^20.0.0",
    "d3-geo": "^3.1.0",
    "topojson-client": "^3.1.0",
    "topojson-server": "^3.0.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
